{
    "manifest_version":3,
    "name":"NoScroll",
    "version": "1.0",

    "description": "A small extension to remove distracting elements from Instagram",

    "browser_specific_settings": {
        "gecko": {
            "id":"no-scroll@lem0n3de8.org",
            "data_collection_permissions": {
                "required": ["none"]
            }
        }
    }, 

    "content_scripts":[
        {
            "matches": ["https://www.instagram.com/*", "www.instagram.com/*", "instagram.com/*"],
            "js":["content/content.js"],
            "css": ["content/content.css"],
            "run_at": "document_end"
        }
    ]
}